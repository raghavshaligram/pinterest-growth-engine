# Copy this file to .env and fill in real values. .env itself is
# gitignored -- never commit real secrets. See auth-middleware.ts /
# client.server.ts / client.ts for exactly how each var is consumed.

# Supabase (server + browser). If this project uses Lovable Cloud,
# reconnecting Supabase there injects these automatically -- you
# shouldn't need to set them by hand in that case.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Pinterest OAuth app (server-only)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=

# Symmetric key used to encrypt/decrypt stored BYOK integration
# credentials (see integrations.server.ts / crypto.server.ts)
INTEGRATIONS_ENC_KEY=
